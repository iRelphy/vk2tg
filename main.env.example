# =========================
# vk2tg configuration (env)
# =========================
#
# How it works:
# - We listen to VK LongPoll for new messages
# - For each VK message we send a formatted copy to all Telegram subscribers

# --- VK ---
# VK API token with access to messages.
VK_TOKEN=

# Optional: forward only selected dialogs (peers).
# Use ONE of these options:
# 1) Single peer:
# VK_PEER_ID=2000000004
# 2) Several peers (comma-separated):
# VK_PEER_IDS=2000000004,2000000005

# If false: do not forward your own outgoing messages (outbox).
VK_FORWARD_OUTBOX=true

# --- Telegram ---
# Telegram bot token (from @BotFather).
TG_TOKEN=

# Where to store subscribers (Telegram chat IDs).
SUBSCRIBERS_FILE=subscribers.json

# --- Debug ---
# If true, we log extra information (helpful while debugging).
DEBUG=true
